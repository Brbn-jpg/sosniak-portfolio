---
const year = new Date().getFullYear();
---

<footer id="contact" class="bg-navy-900 text-white" aria-labelledby="footer-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer content -->
    <div class="py-16 grid md:grid-cols-3 gap-10">

      <!-- Brand column -->
      <div>
        <p class="font-serif text-2xl font-bold text-white mb-2">
          <span class="text-em-400">S</span>ebastian Sośniak
        </p>
        <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
          IVD Sales &amp; Operations Leader. 25+ lat w branży diagnostyki in vitro.
        </p>
        <a
          href="https://www.linkedin.com/in/sebastiansosniak/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-5 text-[#0A66C2] hover:text-[#0958a8] transition-colors duration-200 text-sm font-medium"
          aria-label="LinkedIn Sebastian Sośniak"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          linkedin.com/in/sebastiansosniak
        </a>
      </div>

      <!-- Navigation -->
      <nav aria-label="Nawigacja w stopce">
        <h2 id="footer-heading" class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">
          Nawigacja
        </h2>
        <ul class="space-y-2.5" role="list">
          {
            [
              { label: 'O mnie', href: '#about' },
              { label: 'Kompetencje', href: '#skills' },
              { label: 'Doświadczenie', href: '#experience' },
              { label: 'Edukacja', href: '#education' },
              { label: 'LinkedIn', href: '#linkedin' },
            ].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact -->
      <address class="not-italic">
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">
          Kontakt
        </h2>
        <ul class="space-y-3" role="list">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-em-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-slate-400 text-sm">Warsaw area, Poland</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-em-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a
              href="tel:+48536077539"
              class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
            >
              +48 536-077-539
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-em-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a
              href="mailto:sosniak.seba@gmail.com"
              class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
            >
              sosniak.seba@gmail.com
            </a>
          </li>
        </ul>
      </address>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-slate-500 text-xs">
        &copy; {year} Sebastian Sośniak. Wszelkie prawa zastrzeżone.
      </p>
      <p class="text-slate-600 text-[10px] text-center sm:text-right max-w-sm leading-relaxed">
        <strong class="font-medium text-slate-500">Klauzula RODO:</strong> Dane osobowe zawarte na
        tej stronie są przetwarzane wyłącznie w celu rekrutacji i nawiązania kontaktu zawodowego.
        Administratorem danych jest Sebastian Sośniak. Podstawa prawna: art. 6 ust. 1 lit. a RODO
        (zgoda). Masz prawo dostępu, sprostowania i usunięcia danych.
      </p>
    </div>
  </div>
</footer>
