---
import { useTranslations, type Lang } from '../i18n/utils';
import { experienceData, earlierCareer } from '../i18n/data';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const experiences = experienceData[lang];
const earlier = earlierCareer[lang];
---

<section id="experience" class="py-24 bg-white" aria-labelledby="experience-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-14 reveal">
      <p class="section-label">{t('exp.label')}</p>
      <h2 id="experience-heading" class="section-heading">
        {t('exp.heading')}
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <div class="absolute left-[7px] md:left-[11px] top-2 bottom-2 w-px bg-slate-200 timeline-draw" aria-hidden="true"></div>
      <div class="absolute left-[7px] md:left-[11px] top-2 bottom-2 w-px bg-em-400/50 timeline-progress" aria-hidden="true"></div>

      <ol aria-label={t('exp.timeline.aria')}>
      {
        experiences.map((exp) => (
          <li class="relative pl-8 md:pl-12 pb-10 last:pb-0 reveal">
            <div
              class={`absolute left-0 top-1 w-[15px] h-[15px] md:w-[23px] md:h-[23px] rounded-full border-2 flex items-center justify-center ${
                exp.current
                  ? 'bg-em-400 border-em-400 shadow-[0_0_0_4px_rgba(46,204,139,0.15)]'
                  : 'bg-white border-slate-300'
              }`}
              aria-hidden="true"
            >
              {exp.current && <span class="w-1.5 h-1.5 rounded-full bg-white"></span>}
            </div>

            <div class="group bg-slate-50 border border-slate-200 rounded-xl p-6 md:p-7 hover:border-em-200 hover:shadow-sm transition-all duration-200">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                <div>
                  <h3 class="font-serif text-lg md:text-xl font-bold text-navy-600 leading-tight">
                    {exp.role}
                  </h3>
                  <p class="text-em-500 font-semibold text-sm mt-0.5">{exp.company}</p>
                  <p class="text-slate-400 text-xs mt-0.5 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    {exp.location}
                  </p>
                </div>
                <span
                  class={`shrink-0 text-xs font-semibold px-3 py-1 rounded-full ${
                    exp.current
                      ? 'bg-em-100 text-em-600'
                      : 'bg-slate-100 text-slate-500'
                  }`}
                >
                  {exp.period}
                </span>
              </div>

              <ul class="space-y-2 mb-5" aria-label={`${t('exp.achievements.in')} ${exp.company}`}>
                {exp.highlights.map((h) => (
                  <li class="flex gap-2 text-sm text-slate-600">
                    <svg class="w-4 h-4 text-em-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {h}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2" aria-label={t('exp.tags')}>
                {exp.tags.map((tag) => (
                  <span class="text-xs bg-white border border-slate-200 text-slate-500 px-2.5 py-0.5 rounded-md">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </li>
        ))
      }
      </ol>
    </div>

    <!-- Earlier Career -->
    <div class="mt-10 pl-8 md:pl-12 reveal">
      <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
        {t('exp.earlier')}
      </h3>
      <ul class="flex flex-col sm:flex-row sm:flex-wrap gap-3" role="list">
        {
          earlier.map((item) => (
            <li class="flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-lg px-4 py-3">
              <div class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0" aria-hidden="true"></div>
              <div>
                <p class="text-sm font-medium text-navy-600">{item.role}</p>
                <p class="text-xs text-slate-400">{item.company} · {item.period}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
