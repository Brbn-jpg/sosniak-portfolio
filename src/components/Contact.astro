---
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
---

<section id="contact-form" class="py-24 bg-slate-50" aria-labelledby="contact-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      
      <!-- Left: Contact Info & CTA -->
      <div class="reveal">
        <p class="section-label">Kontakt i Współpraca</p>
        <h2 id="contact-heading" class="section-heading mb-6">
          Porozmawiajmy o&nbsp;przyszłości Twojego laboratorium
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed mb-8">
          Szukasz lidera, który połączy wiedzę kliniczną z wynikami biznesowymi? 
          Jestem otwarty na propozycje strategicznej współpracy, konsultacji rynkowych 
          oraz ról operacyjnych w sektorze IVD i Medical Devices.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-em-500 shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h18" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-navy-600">Zapytania biznesowe</h3>
              <p class="text-sm text-slate-500">Dla firm zainteresowanych restrukturyzacją sprzedaży lub rozwojem rynkowym.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-em-500 shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-navy-600">Networking</h3>
              <p class="text-sm text-slate-500">Budowanie relacji z KOL i liderami innowacji medycznych.</p>
            </div>
          </div>
        </div>

        <!-- Trust Indicator -->
        <div class="mt-12 p-6 bg-navy-600 rounded-2xl text-white relative overflow-hidden">
          <div class="absolute right-0 top-0 opacity-10 translate-x-1/4 -translate-y-1/4">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.45L19.15 19H4.85L12 5.45z"/></svg>
          </div>
          <p class="text-em-400 font-bold text-sm uppercase tracking-widest mb-2">Gwarancja poufności</p>
          <p class="text-slate-200 text-sm leading-relaxed">
            Wszystkie zapytania biznesowe są traktowane jako ściśle poufne. 
            Odpowiadam zazwyczaj w ciągu 24-48 godzin.
          </p>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal bg-white rounded-3xl p-8 md:p-10 shadow-xl shadow-navy-900/5 border border-slate-100">
        <div id="form-container">
          <form id="contact-form-element" action={`https://formspree.io/f/${formspreeId}`} method="POST" class="space-y-5">
            <div class="grid md:grid-cols-2 gap-5">
              <div class="space-y-2">
                <label for="name" class="text-xs font-bold text-navy-600 uppercase tracking-wider">Imię i Nazwisko</label>
                <input 
                  type="text" 
                  id="name" 
                  name="full_name" 
                  required
                  placeholder="Jan Kowalski"
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-navy-600 text-sm focus:outline-none focus:ring-2 focus:ring-em-400/20 focus:border-em-400 transition-all"
                />
              </div>
              <div class="space-y-2">
                <label for="company" class="text-xs font-bold text-navy-600 uppercase tracking-wider">Firma</label>
                <input 
                  type="text" 
                  id="company" 
                  name="company_name" 
                  placeholder="Nazwa organizacji"
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-navy-600 text-sm focus:outline-none focus:ring-2 focus:ring-em-400/20 focus:border-em-400 transition-all"
                />
              </div>
            </div>

            <div class="space-y-2">
              <label for="email" class="text-xs font-bold text-navy-600 uppercase tracking-wider">Adres Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                placeholder="email@firma.pl"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-navy-600 text-sm focus:outline-none focus:ring-2 focus:ring-em-400/20 focus:border-em-400 transition-all"
              />
            </div>

            <div class="space-y-2">
              <label for="subject" class="text-xs font-bold text-navy-600 uppercase tracking-wider">Temat zapytania</label>
              <select 
                id="subject" 
                name="subject"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-navy-600 text-sm focus:outline-none focus:ring-2 focus:ring-em-400/20 focus:border-em-400 transition-all appearance-none cursor-pointer"
              >
                <option value="collaboration">Współpraca biznesowa / COO</option>
                <option value="sales">Doradztwo sprzedażowe IVD</option>
                <option value="recruitment">Proces rekrutacyjny</option>
                <option value="other">Inny temat</option>
              </select>
            </div>

            <div class="space-y-2">
              <label for="message" class="text-xs font-bold text-navy-600 uppercase tracking-wider">Wiadomość</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required
                placeholder="W czym mogę pomóc?"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-navy-600 text-sm focus:outline-none focus:ring-2 focus:ring-em-400/20 focus:border-em-400 transition-all resize-none"
              ></textarea>
            </div>

            <button 
              type="submit" 
              id="submit-button"
              class="w-full bg-em-400 hover:bg-em-500 text-white font-bold py-4 rounded-xl shadow-lg shadow-em-400/20 transition-all duration-300 transform hover:-translate-y-1 active:scale-[0.98] flex items-center justify-center gap-2 group disabled:opacity-70 disabled:cursor-not-allowed"
            >
              <span id="button-text">Wyślij zapytanie</span>
              <svg id="button-icon" class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
              <svg id="loading-spinner" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
            
            <p id="form-error" class="hidden text-red-500 text-xs text-center font-medium mt-2">
              Wystąpił błąd podczas wysyłania. Spróbuj ponownie lub napisz bezpośrednio na email.
            </p>

            <p class="text-[10px] text-center text-slate-400 uppercase tracking-widest pt-2">
              Klikając wyślij, zgadzasz się na przetwarzanie danych w celu kontaktu.
            </p>
          </form>
        </div>

        <!-- Success Message -->
        <div id="success-message" class="hidden text-center py-12">
          <div class="w-20 h-20 bg-em-50 text-em-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif font-bold text-navy-600 mb-2">Dziękuję za kontakt!</h3>
          <p class="text-slate-500 max-w-xs mx-auto mb-8">
            Twoja wiadomość została wysłana. Odpowiem na nią tak szybko, jak to możliwe.
          </p>
          <button 
            id="reset-form"
            class="text-em-500 font-bold text-sm uppercase tracking-wider hover:text-em-600 transition-colors"
          >
            Wyślij kolejną wiadomość
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form-element') as HTMLFormElement;
  const formContainer = document.getElementById('form-container');
  const successMessage = document.getElementById('success-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('button-text');
  const buttonIcon = document.getElementById('button-icon');
  const loadingSpinner = document.getElementById('loading-spinner');
  const formError = document.getElementById('form-error');
  const resetBtn = document.getElementById('reset-form');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // UI Loading state
    submitButton.disabled = true;
    buttonText!.classList.add('hidden');
    buttonIcon!.classList.add('hidden');
    loadingSpinner!.classList.remove('hidden');
    formError!.classList.add('hidden');

    const formData = new FormData(form);
    
    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });

      if (response.ok) {
        formContainer!.classList.add('hidden');
        successMessage!.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error('Form submission failed');
      }
    } catch (error) {
      formError!.classList.remove('hidden');
    } finally {
      submitButton.disabled = false;
      buttonText!.classList.remove('hidden');
      buttonIcon!.classList.remove('hidden');
      loadingSpinner!.classList.add('hidden');
    }
  });

  resetBtn?.addEventListener('click', () => {
    successMessage!.classList.add('hidden');
    formContainer!.classList.remove('hidden');
  });
</script>
