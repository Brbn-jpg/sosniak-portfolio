---
import { Image } from 'astro:assets';
import portraitImg from '../assets/photos/1.jpeg';
---

<section id="about" class="py-24 bg-white overflow-hidden" aria-labelledby="about-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Left: Content -->
      <div class="lg:col-span-7 order-2 lg:order-1">
        <div class="reveal">
          <p class="section-label">O mnie</p>
          <h2 id="about-heading" class="section-heading mb-8">
            Łącząc naukę z&nbsp;biznesem<br/><strong class="text-em-500 font-bold">od&nbsp;25&nbsp;lat</strong>
          </h2>
          <div class="space-y-6 text-slate-600 leading-relaxed text-lg">
            <p class="font-serif italic text-xl md:text-2xl text-navy-600 leading-relaxed">
              „Po 25 latach w tej branży wiem jedno na pewno, dobre procesy i narzędzia są ważne,
              ale bez zaangażowanego zespołu są po prostu nic nie warte."
            </p>
            <p>Dlatego bez względu na to, z kim pracuję lub z kim rozmawiam, czy to dyrektor, technik, diagnosta, sprzątaczka czy kurier, podchodzę do każdego tak samo, z uwagą i szacunkiem. Ludzie czują kiedy są naprawdę zauważeni. I to właśnie buduje zespoły, z którymi chce się pracować.</p>
          </div>

          <!-- Language badges -->
          <div class="mt-10 flex flex-wrap gap-4">
            {
              [
                { lang: 'Polski',    level: 'Ojczysty',            code: 'PL' },
                { lang: 'Angielski', level: 'Zawodowy',            code: 'EN' },
                { lang: 'Francuski', level: 'Średniozaawansowany', code: 'FR' },
              ].map((item) => (
                <div class="flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 hover:border-em-200 transition-colors">
                  <span class="text-[10px] font-bold font-mono tracking-widest text-white bg-navy-600 rounded px-1.5 py-1 shrink-0">{item.code}</span>
                  <div>
                    <p class="text-xs font-bold text-navy-600 uppercase tracking-tight">{item.lang}</p>
                    <p class="text-[10px] text-slate-500 font-medium uppercase tracking-wider">{item.level}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Right: Portrait Photo -->
      <div class="lg:col-span-5 order-1 lg:order-2 reveal relative">
        <div class="relative">
          <!-- Decorative background element -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-em-50 rounded-2xl -z-10" aria-hidden="true"></div>
          <div class="absolute -bottom-6 -left-6 w-48 h-48 border-b-2 border-l-2 border-em-200 rounded-bl-3xl -z-10" aria-hidden="true"></div>

          <!-- Main Image Container -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-navy-900/10 border border-slate-200">
            <Image
              src={portraitImg}
              alt="Sebastian Sośniak - COO & IVD Sales Leader"
              class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-700"
              quality="high"
            />
            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-navy-900/40 via-transparent to-transparent opacity-60"></div>
          </div>

          <!-- Floating Badge -->
          <div class="absolute bottom-6 -left-4 md:-left-8 bg-white border border-slate-100 rounded-xl p-4 shadow-xl shadow-navy-900/5 reveal-stagger">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-em-400 flex items-center justify-center text-white shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-wider font-bold text-slate-400 leading-none mb-1">Status</p>
                <p class="text-sm font-bold text-navy-600 leading-none">Gotowy na nowe wyzwania</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Highlight cards integrated into the bottom of the section -->
    <div class="reveal-stagger grid grid-cols-2 md:grid-cols-4 gap-4 mt-16">
      {
        [
          {
            icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>`,
            title: 'P&L Leadership',
            desc: 'Budżetowanie i wyniki',
          },
          {
            icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
            title: 'Zespół 18 osób',
            desc: 'Rozwój talentów',
          },
          {
            icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>`,
            title: 'MBA + MSc',
            desc: 'Podwójna ekspertyza',
          },
          {
            icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
            title: 'Region EMEA',
            desc: 'Skala międzynarodowa',
          },
        ].map((card) => (
          <div class="bg-slate-50/50 border border-slate-100 rounded-xl p-4 hover:border-em-200 hover:bg-white hover:shadow-sm transition-all duration-300 text-center lg:text-left">
            <div class="text-em-500 mb-2.5 flex justify-center lg:justify-start" set:html={card.icon} />
            <h3 class="font-bold text-navy-600 text-xs uppercase tracking-tight mb-0.5">{card.title}</h3>
            <p class="text-slate-500 text-[10px] leading-relaxed uppercase tracking-wider font-medium">{card.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
