---
const navLinks = [
  { label: 'O mnie', href: '#about' },
  { label: 'Kompetencje', href: '#skills' },
  { label: 'Doświadczenie', href: '#experience' },
  { label: 'Edukacja', href: '#education' },
  { label: 'Kontakt', href: '#contact-form' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  aria-label="Nawigacja główna"
>
  <!-- Scroll-progress indicator (scroll-driven, Chrome/Edge/Safari; hidden elsewhere) -->
  <div id="scroll-progress" aria-hidden="true"></div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Name -->
      <a
        href="/"
        class="font-serif text-lg font-bold text-white transition-colors duration-200"
        aria-label="Sebastian Sosniak - strona główna"
      >
        <span class="text-em-400">S</span>ebastian Sosniak
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link px-3 py-3 rounded-md text-sm text-white/80 hover:text-white hover:bg-white/10 transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-3 rounded-md text-white/80 hover:text-white hover:bg-white/10 transition-colors duration-200"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-white/10 bg-navy-600/95 backdrop-blur-sm"
    role="navigation"
    aria-label="Menu mobilne"
  >
    <ul class="px-4 py-3 space-y-1" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block px-3 py-3 rounded-md text-sm text-white/80 hover:text-white hover:bg-white/10 transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav')!;
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll-aware nav background
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      nav.classList.add('bg-navy-600/95', 'backdrop-blur-sm', 'shadow-lg');
    } else {
      nav.classList.remove('bg-navy-600/95', 'backdrop-blur-sm', 'shadow-lg');
    }
  });

  // Mobile toggle
  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
