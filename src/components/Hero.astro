---
---

<header
  class="relative min-h-[85vh] flex items-center bg-navy-600 overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Diagonal-stripe pattern -->
  <div class="absolute inset-0 opacity-[0.055]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="diagonals" width="20" height="20" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="20" stroke="white" stroke-width="0.6"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#diagonals)" />
    </svg>
  </div>

  <!-- Central Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-4xl max-h-4xl bg-em-400/10 blur-[120px] rounded-full pointer-events-none" aria-hidden="true"></div>

  <!-- Emerald vertical accent lines -->
  <div class="absolute top-0 left-8 lg:left-16 w-px h-full opacity-10"
    style="background: linear-gradient(to bottom, transparent 0%, var(--color-em-400) 20%, var(--color-em-400) 80%, transparent 100%);"
    aria-hidden="true"
  ></div>
  <div class="absolute top-0 right-8 lg:right-16 w-px h-full opacity-10"
    style="background: linear-gradient(to bottom, transparent 0%, var(--color-em-400) 20%, var(--color-em-400) 80%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <div class="hero-parallax relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 pt-32 lg:py-32 lg:pt-40 w-full text-center">
    
    <!-- Eyebrow -->
    <p
      class="text-em-400 text-sm font-bold uppercase tracking-[0.3em] mb-6 opacity-0 animate-[fadeIn_0.6s_cubic-bezier(0.23,1,0.32,1)_0.1s_forwards]"
    >
      IVD Strategic Leadership
    </p>

    <!-- H1 -->
    <h1
      id="hero-heading"
      class="font-serif text-5xl sm:text-7xl lg:text-8xl font-bold text-white leading-[1.05] tracking-tight mb-8 opacity-0 animate-[fadeUp_0.8s_cubic-bezier(0.23,1,0.32,1)_0.2s_forwards]"
    >
      IVD Sales &amp;<br/>Operations Leader
      <span class="block text-em-400 mt-2">Chief Operating Officer</span>
    </h1>

    <!-- Name tag -->
    <div
      class="inline-flex items-center gap-3 bg-white/[0.05] border border-white/10 rounded-full px-6 py-2 mb-10 opacity-0 animate-[fadeIn_0.6s_cubic-bezier(0.23,1,0.32,1)_0.35s_forwards]"
    >
      <span class="w-2 h-2 rounded-full bg-em-400" aria-hidden="true"></span>
      <span class="text-white/90 text-base font-medium tracking-wide">Sebastian Sosniak</span>
    </div>

    <!-- Subtitle -->
    <p
      class="text-slate-300/90 text-xl sm:text-2xl leading-relaxed mb-12 max-w-3xl mx-auto opacity-0 animate-[fadeUp_0.7s_cubic-bezier(0.23,1,0.32,1)_0.5s_forwards]"
    >
      Ponad 25 lat doświadczenia w branży IVD &mdash; od operacji laboratoryjnych do strategicznego
      przywództwa komercyjnego. Udokumentowane wyniki sprzedażowe w regionie EMEA, zarządzanie
      P&amp;L i transformacja cyfrowa.
    </p>

    <!-- CTA buttons -->
    <div
      class="flex flex-wrap justify-center gap-4 opacity-0 animate-[fadeUp_0.6s_cubic-bezier(0.23,1,0.32,1)_0.65s_forwards]"
    >
      <a href="/cv-sebastian-sosniak.pdf" download="CV_Sebastian_Sosniak.pdf" class="btn-primary text-lg px-8 py-4" aria-label="Pobierz CV Sebastian Sosniak (PDF)">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Pobierz CV
      </a>
      <a
        href="https://www.linkedin.com/in/sebastiansosniak/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-linkedin text-lg px-8 py-4"
        aria-label="Profil LinkedIn Sebastian Sosniak (otworzy się w nowej karcie)"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <!-- Stats strip -->
    <div
      class="mt-20 pt-10 border-t border-white/10 grid grid-cols-3 gap-8 max-w-3xl mx-auto opacity-0 animate-[fadeIn_0.8s_cubic-bezier(0.23,1,0.32,1)_0.8s_forwards]"
      aria-label="Kluczowe liczby"
    >
      {
        [
          { count: 25, suffix: '+', label: 'Lat w branży IVD' },
          { count: 7,  suffix: '',  label: 'Krajów NEEU' },
          { count: 110, suffix: '%', label: 'Realizacja targetów' },
        ].map((stat) => (
          <div class="text-center">
            <p
              class="font-serif text-4xl sm:text-5xl font-bold text-em-400 tabular-nums"
              data-count={stat.count}
              data-suffix={stat.suffix}
            >
              {stat.count}{stat.suffix}
            </p>
            <p class="text-white/60 text-xs sm:text-sm mt-2 leading-snug uppercase tracking-widest font-semibold">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</header>

<script>
  const parallaxEl = document.querySelector<HTMLElement>('.hero-parallax');
  if (
    parallaxEl &&
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches
  ) {
    const hero = parallaxEl.closest('header') as HTMLElement;
    window.addEventListener(
      'scroll',
      () => {
        const y = window.scrollY;
        const limit = hero.offsetHeight * 1.3;
        if (y < limit) {
          parallaxEl.style.transform = `translateY(${y * 0.12}px)`;
        } else {
          parallaxEl.style.transform = '';
        }
      },
      { passive: true }
    );
  }
</script>
