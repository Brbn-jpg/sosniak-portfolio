---
import { useTranslations, type Lang } from '../i18n/utils';
import { educationData } from '../i18n/data';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const { degrees, certs } = educationData[lang];

function cardClasses(h: string | boolean) {
  if (h === 'primary')  return 'bg-navy-600 border-navy-500';
  if (h === 'clinical') return 'bg-em-50 border-em-200 hover:border-em-300';
  return 'bg-white border-slate-200 hover:border-em-200';
}

function iconClasses(h: string | boolean) {
  if (h === 'primary')  return 'bg-em-400/20 text-em-400';
  if (h === 'clinical') return 'bg-em-400/20 text-em-500';
  return 'bg-navy-50 text-navy-400';
}

function degreeClasses(h: string | boolean) {
  return h === 'primary' ? 'text-white' : 'text-navy-600';
}

function badgeClasses(h: string | boolean) {
  if (h === 'primary')  return 'bg-em-400/20 text-em-400';
  if (h === 'clinical') return 'bg-em-200/50 text-em-700';
  return 'bg-slate-100 text-slate-400';
}

function institutionClasses(h: string | boolean) {
  if (h === 'primary')  return 'text-em-400';
  if (h === 'clinical') return 'text-em-600';
  return 'text-em-500';
}
---

<section id="education" class="py-24 bg-slate-50" aria-labelledby="education-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-14 reveal">
      <p class="section-label">{t('edu.label')}</p>
      <h2 id="education-heading" class="section-heading">
        {t('edu.heading')}
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Education degrees -->
      <div class="reveal">
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
          {t('edu.degrees')}
        </h3>
        <ul class="space-y-3" role="list">
          {
            degrees.map((edu) => (
              <li class={`border rounded-xl p-5 hover:shadow-sm transition-all duration-200 ${cardClasses(edu.highlight)}`}>
                <div class="flex gap-4 items-start">
                  <div class={`w-10 h-10 rounded-lg flex items-center justify-center shrink-0 ${iconClasses(edu.highlight)}`}>
                    <span set:html={edu.icon} />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2">
                      <h4 class={`font-serif font-bold text-sm leading-snug ${degreeClasses(edu.highlight)}`}>{edu.degree}</h4>
                      <span class={`shrink-0 text-[11px] font-medium px-2 py-0.5 rounded-full ${badgeClasses(edu.highlight)}`}>{edu.years}</span>
                    </div>
                    <p class={`text-xs mt-1 font-medium ${institutionClasses(edu.highlight)}`}>{edu.institution}</p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Certifications -->
      <div class="reveal">
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-6">
          {t('edu.certs')}
        </h3>
        <ul class="space-y-3" role="list">
          {
            certs.map((cert) => (
              <li class="bg-white border border-slate-200 rounded-xl px-5 py-4 hover:border-em-200 hover:shadow-sm transition-all duration-200">
                <div class="flex items-start justify-between gap-3 mb-0.5">
                  <h4 class="font-semibold text-navy-600 text-sm leading-snug">{cert.name}</h4>
                  <span class="shrink-0 text-[11px] text-slate-400 font-medium tabular-nums">{cert.year}</span>
                </div>
                <p class="text-xs text-slate-400">{cert.issuer}</p>
                {cert.description && <p class="text-xs text-slate-500 mt-0.5 italic">{cert.description}</p>}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
