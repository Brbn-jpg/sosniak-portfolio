---
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Sebastian Sośniak | Lider Sprzedaży i Operacji IVD | COO',
  description = 'Doświadczony menedżer IVD z ponad 25-letnim stażem w operacjach laboratoryjnych i przywództwie komercyjnym. MBA, odpowiedzialność za P&L i rozwój zespołów sprzedaży na rynku EMEA urządzeń medycznych.',
  canonical = 'https://metricmind.com',
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sebastian Sośniak',
  jobTitle: 'Dyrektor Operacyjny',
  description: description,
  url: canonical,
  sameAs: ['https://www.linkedin.com/in/sebastiansosniak/'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Warsaw',
    addressCountry: 'PL',
  },
  email: 'sosniak.seba@gmail.com',
  telephone: '+48536077539',
  knowsAbout: [
    'In Vitro Diagnostics',
    'Medical Devices',
    'Sales Leadership',
    'P&L Management',
    'Clinical Chemistry',
    'Hematology',
    'Hemostasis',
    'Immunochemistry',
    'Laboratory Operations',
    'Digital Transformation',
    'Key Account Management',
    'Distributor Management',
    'Tender & Public Procurement',
    'Customer Segmentation',
    'Business Development',
  ],
  image: 'https://metricmind.com/og-image.jpg',
  alumniOf: [
    {
      '@type': 'CollegeOrUniversity',
      name: 'Uniwersytet Ekonomiczny we Wrocławiu',
    },
    {
      '@type': 'CollegeOrUniversity',
      name: 'Akademia Medyczna we Wrocławiu',
    },
    {
      '@type': 'CollegeOrUniversity',
      name: 'Uniwersytet Wrocławski',
    },
  ],
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content="https://metricmind.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://metricmind.com/og-image.jpg" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts: preconnect + non-blocking load (avoids render-blocking @import) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
      />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <meta name="robots" content="index, follow" />
    <meta name="author" content="Sebastian Sośniak" />
  </head>
  <body>
    <!-- Skip-to-main link (WCAG 2.4.1 Bypass Blocks, Level A) -->
    <a
      href="#main-content"
      class="fixed top-0 left-1/2 -translate-x-1/2 -translate-y-full focus-visible:translate-y-0 z-[200] bg-em-400 text-white px-5 py-2.5 rounded-b-lg font-medium text-sm transition-transform duration-200 focus-visible:outline-none shadow-lg"
    >
      Przejdź do treści
    </a>

    <slot />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-stagger, .timeline-draw').forEach((el) => {
        observer.observe(el);
      });

      // Number counter animation
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const target = parseFloat(el.dataset.count || '0');
              const suffix = el.dataset.suffix || '';

              if (prefersReducedMotion) {
                el.textContent = target + suffix;
                counterObserver.unobserve(el);
                return;
              }

              const duration = 1800;
              const start = performance.now();

              const update = (now: number) => {
                const progress = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = Math.floor(eased * target);
                el.textContent = current + suffix;
                if (progress < 1) requestAnimationFrame(update);
              };

              requestAnimationFrame(update);
              counterObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.5 }
      );

      document.querySelectorAll('[data-count]').forEach((el) => {
        counterObserver.observe(el);
      });
    </script>
  </body>
</html>
